<%-include("partials/header")%>

<div class="container py-5 px-5">
  <% if (message) { %>
    <div class="alert alert-success" role="alert"><%= message %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert alert-danger" role="alert"><%= error %></div>
  <% } %>

  <form action="/edit/<%= product._id %>" method="post">
    <div class="mb-3">
      <label for="name" class="form-label">Name*</label>
      <input type="text" class="form-control" id="name" required name="name" autocomplete="off" value="<%= product.name %>">
    </div>
    <div class="mb-3">
      <label for="price" class="form-label">Price (in Rs)*</label>
      <input type="number" class="form-control" id="price" required name="price" autocomplete="off" value="<%= product.price %>">
    </div>
    <div class="mb-3">
      <label for="exampleFormControlTextarea1">Description*</label>
      <textarea class="form-control" id="exampleFormControlTextarea1" rows="4" required name="description"><%= product.description %></textarea>
    </div>
    <div class="mb-3">
      <label id="checkbox">Select type</label>
      <div class="form-check">
        <input class="form-check-input" type="radio" name="radio" id="exampleRadios1" value="Books and Novels" <%= product.type === 'Books and Novels' ? 'checked' : '' %>>
        <label class="form-check-label" for="exampleRadios1">Books and Novels</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="radio" name="radio" id="exampleRadios2" value="Stationery" <%= product.type === 'Stationery' ? 'checked' : '' %>>
        <label class="form-check-label" for="exampleRadios2">Stationery</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="radio" name="radio" id="exampleRadios3" value="Electronics Appliances" <%= product.type === 'Electronics Appliances' ? 'checked' : '' %>>
        <label class="form-check-label" for="exampleRadios3">Electronics Appliances</label>
      </div>
      <div class="form-check">
        <input class="form-check-input" type="radio" name="radio" id="exampleRadios4" value="Other" <%= product.type === 'Other' ? 'checked' : '' %>>
        <label class="form-check-label" for="exampleRadios4">Other</label>
      </div>
    </div>
    <button type="submit" class="btn btn-primary">Update Product</button>
  </form>
</div>

<%-include("partials/footer")%>
